ios/Flutter/Flutter.podspec.lock

# macOS-specific
/macos/Flutter/ephemeral/
/macos/.symlinks/
/macos/Flutter/Flutter.podspec
macos/Flutter/Flutter.framework

# Web-specific files
web/.dart_tool/
/web/manifest.json

# Windows-specific files
/windows/.dart_tool/
windows/flutter/ephemeral

# Linux-specific files
/linux/flutter/ephemeral
/linux/.dart_tool/

# JetBrains IDE files (IntelliJ, PyCharm, Android Studio, etc.)
.idea/
*.iml

# VS Code files
.vscode/
.settings/
.history/

# Xcode-related files
*.xcworkspace
*.xcodeproj
*.xcuserstate

# macOS Finder
.DS_Store

# Generated files by CocoaPods (for iOS and macOS)
ios/Pods/
macos/Pods/

# Generated XCFrameworks
**/Flutter.xcframework/

# Temporary files created by the system or development tools
*.tmp
*.temp
*.bak

# Flutter pubspec.lock for libraries (not apps)
pubspec.lock

# Debug files and logs
debug.log
error.log

# Logs from third-party services
*.log